{
  "file_scan_exclusions": [
    "firebase-debug.log",
    "firestore-debug.log",
    "ui-debug.log",
    "node_modules",
    ".git",
    ".next",
    ".beads",
    "LICENSE"
  ],
  "languages": {
    "CSS": {
      "code_actions_on_format": {
        "source.action.useSortedKeys.biome": true,
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      },
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      }
    },
